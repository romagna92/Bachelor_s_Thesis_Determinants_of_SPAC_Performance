Cell[BoxData[
 RowBox[{"lmCSRlog", " ", "=", " ", 
  RowBox[{"LinearModelFit", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"updatedCrossSectionalData", "[", 
      RowBox[{
       RowBox[{"#", "&"}], ",", " ", 
       RowBox[{
        RowBox[{"{", " ", 
         RowBox[{
         "#logAnnouncementTiming", ",", " ", "#preVoteShareOverCash", ",", 
          " ", "#logIPOSize", ",", " ", "#SponsorOwnership", ",", " ", 
          "#WarrantsOverPublicShares", ",", " ", "#Rights", ",", " ", 
          "#TargetSize", ",", " ", "#TargetROA", ",", " ", "#TargetDebtRatio",
