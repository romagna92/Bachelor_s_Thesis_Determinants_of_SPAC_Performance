Cell["\<\
There appears to be a non-linear relationship between \
\[OpenCurlyDoubleQuote]IPO Size\[CloseCurlyDoubleQuote] and the dependent \
variable. This can be fixed by taking the logarithm of \
\[OpenCurlyDoubleQuote]IPO Size\[CloseCurlyDoubleQuote]\
\>", "Item",
 CellChangeTimes->{{3.8679140216193123`*^9, 3.867914048955344*^9}, {
  3.867914130100689*^9, 3.867914153641983*^9}, {3.867914730652046*^9, 
  3.867914730652178*^9}},ExpressionUUID->"20016bc6-8f01-4072-bfd5-\
a7d3359df342"],

Cell["\<\
The variance of the dependent variable appears to be decreasing with larger \
values for \[OpenCurlyDoubleQuote]announcement \
timing\[CloseCurlyDoubleQuote]. Since a positive correlation between variance \
of the dependent variable and an independent variable is fixed by taking the \
logarithm of the dependent variable, I theorize a negative correlation should \
be fixed by taking the log of the independent variable.\
\>", "Item",
 CellChangeTimes->{{3.8679140216193123`*^9, 3.867914048955344*^9}, {
  3.867914130100689*^9, 3.867914153641983*^9}, {3.867914741525778*^9, 
  3.8679149503311367`*^9}},ExpressionUUID->"4681a219-a254-4f15-9c82-\
2947ec62aceb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Adding the Log of \[OpenCurlyDoubleQuote]IPO Size\[CloseCurlyDoubleQuote] and \
\[OpenCurlyDoubleQuote]announcement timing\[CloseCurlyDoubleQuote] as \
variables and creating the updated scatterplot and correlation matrix\
\>", "Subsubsection",
 CellChangeTimes->{{3.867914166067486*^9, 3.867914215696515*^9}, {
  3.867914958892157*^9, 
  3.867914969768495*^9}},ExpressionUUID->"145c0d01-e727-4075-b5ba-\
04e38d9239f5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"updatedCrossSectionalData", " ", "=", " ", 
   RowBox[{"updatedCrossSectionalData", "[", 
    RowBox[{"All", ",", " ", 
     RowBox[{
      RowBox[{"Append", "[", 
       RowBox[{"#", ",", " ", 
        RowBox[{"\"\<logIPOSize\>\"", "\[Rule]", " ", 
         RowBox[{"Log", "[", "#IPOSize", "]"}]}]}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"updatedCrossSectionalData", " ", "=", " ", 
   RowBox[{"updatedCrossSectionalData", "[", 
    RowBox[{"All", ",", " ", 
     RowBox[{
      RowBox[{"Append", "[", 
       RowBox[{"#", ",", " ", 
        RowBox[{"\"\<logAnnouncementTiming\>\"", "\[Rule]", " ", 
         RowBox[{"Log", "[", "#AnnouncementTiming", "]"}]}]}], "]"}], "&"}]}],
     "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.867913578427952*^9, 3.867913646794344*^9}, {
  3.867914511940362*^9, 3.867914568069447*^9}},
 CellLabel->
