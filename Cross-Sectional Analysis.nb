Cell[CellGroupData[{

Cell["Attempting to fix the problem by using a log-lin model", "Subsection",
 CellChangeTimes->{{3.867845536209305*^9, 
  3.8678455459280777`*^9}},ExpressionUUID->"15ae31f1-79e0-4980-90fa-\
7ce9c127f43b"],

Cell["\<\
Since I can\[CloseCurlyQuote]t apply a log transformation to the returns of \
the SPACs due to some of them being negative, I have to restate the dependent \
variable. To do that, I will index the the share price of the SPAC to 100 one \
day after the merger vote, and calculate the point score one year later based \
on the one-year post merger performance\
\>", "Item",
 CellChangeTimes->{{3.8678446857747793`*^9, 
  3.867844852846324*^9}},ExpressionUUID->"3dc50182-1d6e-4842-9d16-\
720e91b2ab11"],

Cell[CellGroupData[{

Cell["\<\
Adding the new performance metric and its logarithm to the dataset\
\>", "Subsubsection",
 CellChangeTimes->{{3.867845338955634*^9, 
  3.867845370931316*^9}},ExpressionUUID->"bfa905be-cbb6-4bb5-a7a4-\
12f505a86292"],

Cell[BoxData[
 RowBox[{
  RowBox[{"updatedCrossSectionalData", " ", "=", " ", 
   RowBox[{"CrossSectionalData", "[", 
    RowBox[{"All", ",", " ", 
     RowBox[{
      RowBox[{"Append", "[", 
       RowBox[{"#", ",", " ", 
        RowBox[{"\"\<PerformanceScore\>\"", "\[Rule]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"#OneYearPerformance", "*", "100"}], "+", "100"}], 
          ")"}]}]}], "]"}], "&"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.867844861650694*^9, 3.8678449720928917`*^9}, 
   3.8678450357063837`*^9},
 CellLabel->
  "In[106]:=",ExpressionUUID->"d5296c89-e5fc-4504-ae24-f182b4e9e7cc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"updatedCrossSectionalData", " ", "=", " ", 
    RowBox[{"updatedCrossSectionalData", "[", 
     RowBox[{"All", ",", " ", 
      RowBox[{
       RowBox[{"Append", "[", 
        RowBox[{"#", ",", " ", 
         RowBox[{"\"\<logPerformanceScore\>\"", "\[Rule]", " ", 
          RowBox[{"Log", "[", "#PerformanceScore", "]"}]}]}], "]"}], "&"}]}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.867845043057542*^9, 3.8678451159994164`*^9}},
 CellLabel->
  "In[107]:=",ExpressionUUID->"df0805b5-dd7b-4d03-b18d-e8c3aa154183"]
}, Open  ]],

