Cell["\<\
The P-Value for the Jarque-Bera test indicates Skewness and excess Kurtosis  \
not to be equal to zero at a 10% level of significance.\
\>", "Item",
 CellChangeTimes->{{3.867846604053075*^9, 3.8678466779854803`*^9}, {
  3.867846760920466*^9, 3.867846771595586*^9}, {3.869229505803802*^9, 
  3.8692295410192747`*^9}, {3.869229671341951*^9, 
  3.8692296860218487`*^9}},ExpressionUUID->"22c0c809-1f0c-4848-acc5-\
1ffeeb19f14d"],

Cell["\<\
According to my notes from last years statistics class this is only an issue \
when calculating prediction bands. Since no prediction bands are calculated \
in this analysis, the Skewness and/or excess Kurtosis is not addressed.\
\>", "Item",
 CellChangeTimes->{{3.867846604053075*^9, 3.8678466779854803`*^9}, {
  3.867846760920466*^9, 3.867846771595586*^9}, {3.869229505803802*^9, 
  3.869229656906745*^9}},ExpressionUUID->"08c0a170-de4a-4a9e-8783-\
b77b14e203d5"]
}, Open  ]],

