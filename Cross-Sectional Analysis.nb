Cell[CellGroupData[{

Cell["\<\
Since the P-Value of 1 is higher than any significance level used in \
statistics, the conclusion is, that heteroscedasticity is present.\
\>", "Item",
 CellChangeTimes->{{3.867843216866707*^9, 3.867843286329282*^9}, {
