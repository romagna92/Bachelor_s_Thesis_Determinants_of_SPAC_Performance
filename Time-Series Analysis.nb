Cell["\<\
The quantile plot indicates light tails and maybe a slight positive skew.\
\>", "Item",
 CellChangeTimes->{{3.868010809515731*^9, 3.868010826592045*^9}, {
  3.868010942410746*^9, 3.8680109542591553`*^9}, {3.8680110002747583`*^9, 
