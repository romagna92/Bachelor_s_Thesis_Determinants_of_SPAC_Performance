   3.869223461818138*^9},ExpressionUUID->"e4f07a5a-a37f-4e76-860e-\
659fd3dd73ee"],

Cell["deSPAC Name:\t\t\tName of the post-merger company", "Item",
 CellChangeTimes->{{3.8692233470480623`*^9, 3.869223369130777*^9}, 
   3.8692234629162083`*^9},ExpressionUUID->"68b21313-3fdc-4363-a279-\
314761040565"],

Cell["IPODate:\t\t\tDate of the SPAC\[CloseCurlyQuote]s IPO", "Item",
 CellChangeTimes->{{3.8692233470480623`*^9, 3.869223381309576*^9}, 
   3.86922346424901*^9},ExpressionUUID->"52f1e295-e4ac-4865-a7e2-\
734e0767dfa3"],

Cell["AcquisitionDeadlineDate: \tThe acquisition deadline", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 
  3.867679247049844*^9}},ExpressionUUID->"d445acb4-239b-42a4-8ec4-\
7a345a9454ed"],

Cell["MergerVoteDate: \t\tDate of the vote on the merger", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 
  3.86767924919879*^9}},ExpressionUUID->"8d00ee97-978b-4383-a72c-\
420d692ac9aa"],

Cell["IPOYear:\t\t\tThe year in which the SPAC went public", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 
  3.867679273312101*^9}},ExpressionUUID->"77e923b4-c1a2-4b17-b488-\
4ab6b51ee962"],

Cell["\<\
AcquisitionYear:\t\tThe year in which the SPAC carried out a merger\
\>", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 
  3.8676792971944437`*^9}},ExpressionUUID->"0b5a5f61-32c3-489d-83d1-\
49efd794a805"],

Cell["\<\
AnnouncementTiming:\t\tthe minimum of: the no. days between an IPO and the \
acquisition announcement date, or the no. of days between the acquisition \
announcement date and the merger deadline\
\>", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 
  3.867679376611271*^9}},ExpressionUUID->"12d6561a-4494-40ae-80e8-\
f69a5682c915"],

Cell["\<\
preVoteShareOverCash:\tShare price of the SPAC one day before the merger vote \
minus the cash in trust per share\
\>", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 
  3.867679436169405*^9}},ExpressionUUID->"428993db-0dfb-4f84-917b-\
f8875e18a717"],

Cell["\<\
OneYearPerformance:\t\tThe performance of the post-merger company share price \
one year after the merger vote\
\>", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 
  3.867679474997031*^9}},ExpressionUUID->"c596c762-4013-4982-8ee7-\
bab74167e67b"],

Cell["\<\
OneYearAR:\t\t\tThe abnormal return (Russell 2000 as benchmark) of the \
post-merger company share price one year after the merger\
\>", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 
  3.86767953883604*^9}},ExpressionUUID->"65bbad66-a1e6-45dd-a6ba-\
3180c0b1253f"],

Cell["IPOSize:\t\t\tPublic Proceeds from the SPAC\[CloseCurlyQuote]s IPO", \
"Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 
  3.8676795618118687`*^9}},ExpressionUUID->"82e64563-faa3-469a-9468-\
1d5f6b7d4a65"],

Cell["\<\
extraCashInTrust:\t\testimated redemption value per share minus 10$\
\>", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 
  3.8676796005599213`*^9}},ExpressionUUID->"945598f6-f0d9-428b-b0ad-\
29286bf8bcaf"],

Cell["\<\
SponsorOwnership:\t\tSponsor shares divided by public + sponsor shares\
\>", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 3.867679593278475*^9}, {
  3.8676796556477737`*^9, 
  3.867679698000614*^9}},ExpressionUUID->"87194840-9fb3-4123-b38a-\
0425c496d9ec"],

Cell["\<\
Warrants/publichShares:\tno. of warrants divided by the no. of public shares\
\>", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 3.867679593278475*^9}, {
  3.8676796556477737`*^9, 
  3.867679733499176*^9}},ExpressionUUID->"b018506a-95ac-43fe-9ef0-\
f01e4ae8ba11"],

Cell["\<\
Rights:\t\t\t\tdummy variable; 1 if rights are included in the units, 0 \
otherwise\
\>", "Item",
 CellChangeTimes->{{3.8676791893521442`*^9, 3.867679593278475*^9}, {
  3.8676796556477737`*^9, 
  3.867679761737694*^9}},ExpressionUUID->"5d235486-6035-4197-9a17-\
d0ee11276598"],

Cell["\<\
SPACPeriodReturn:\t\tThe return earned on shares during the period from the \
IPO to the redemption deadline\
\>", "Item",
 CellChangeTimes->{{3.869223402540908*^9, 
  3.8692234691016703`*^9}},ExpressionUUID->"749b12e2-c070-4030-964c-\
b97635430834"],

Cell["\<\
SPACPeriodAR:\t\t\tThe AR earned on shares during the period from the IPO to \
