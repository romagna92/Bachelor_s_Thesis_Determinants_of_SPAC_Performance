Cell["Adding AR for the short-position", "Subsubsection",
 CellChangeTimes->{{3.868103185350019*^9, 3.868103216878847*^9}, {
  3.8681034267847233`*^9, 
  3.8681034380762157`*^9}},ExpressionUUID->"8a879985-16b1-48c8-a5ec-\
a849af8b3e4d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CrossSectionalData", " ", "=", " ", 
   RowBox[{"CrossSectionalData", "[", 
    RowBox[{"All", ",", " ", 
     RowBox[{
      RowBox[{"Append", "[", 
       RowBox[{"#", ",", " ", 
        RowBox[{"\"\<shortAR\>\"", "\[Rule]", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"#OneYearPerformance", "*", 
             RowBox[{"-", "1"}]}], ")"}], " ", "-", 
           RowBox[{"(", 
            RowBox[{"#OneYearPerformance", "-", "#OneYearAR"}], ")"}]}], 
          ")"}]}]}], "]"}], "&"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.868103224010502*^9, 3.8681033003553743`*^9}, 
   3.868103334469377*^9, {3.8681034460384207`*^9, 3.868103462571225*^9}, {
